local old
old = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    local args = {...}

    -- If toggle is OFF, do nothing
    if not antiContestenabled then
        return old(self, ...)
    end

    if not checkcaller() and method == "FireServer" and self == remote then
        local data = args[1]

        if typeof(data) == "table" and data.CharacterModel == lp.Character then

            local validShots = {
                JumpShot = true,
                MovingShot = true,
                Layup = true
            }

            -- StartShotAction with ShotType
            if data.ClassName == "StartShotAction" and validShots[data.ShotType] then
                hum.HipHeight = 10
                task.delay(1, function()
                    hum.HipHeight = 2
                end)
            end

            -- StartDunkAction
            if data.ClassName == "StartDunkAction" then
                hum.HipHeight = 10
                task.delay(1, function()
                    hum.HipHeight = 2
                end)
            end
        end
    end

    return old(self, ...)
end)

