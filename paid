-- =========================================
-- MAIN LOOP
-- =========================================

local CurrentTargetV1
local CurrentTargetV2
local CurrentTargetLegit
local lastMoveDir = Vector3.zero
local currentSpeed = 0

RunService.RenderStepped:Connect(function()

	if not Character or not HRP or not Humanoid then return end

	-- V1
	if _G.AutoGuardV1 then
		CurrentTargetV1 = CurrentTargetV1 or GetClosestPlayer()
		if CurrentTargetV1 and CurrentTargetV1.Character then
			local t = CurrentTargetV1.Character:FindFirstChild("HumanoidRootPart")
			if t then
				local pos = t.Position + t.CFrame.LookVector * _G.GuardDistanceV1
				Humanoid:Move((pos - HRP.Position).Unit, false)
			end
		end
	end

	-- V2
	if _G.AutoGuardV2 then
		CurrentTargetV2 = CurrentTargetV2 or GetClosestPlayer()
		if CurrentTargetV2 and CurrentTargetV2.Character then
			local t = CurrentTargetV2.Character:FindFirstChild("HumanoidRootPart")
			if t then
				local predicted = t.Position + t.Velocity * 0.12
				local pos = predicted + t.CFrame.LookVector * _G.GuardDistanceV2
				Humanoid:Move((pos - HRP.Position).Unit, false)
			end
		end
	end

	-- Legit
	if _G.LegitAutoGuard then
		CurrentTargetLegit = CurrentTargetLegit or GetClosestPlayer()
		if CurrentTargetLegit and CurrentTargetLegit.Character then
			local t = CurrentTargetLegit.Character:FindFirstChild("HumanoidRootPart")
			if t then
				local predicted = t.Position + t.Velocity * 0.12
				local pos = predicted + t.CFrame.LookVector * _G.LegitGuardDistance

				local dir = (pos - HRP.Position)
				if dir.Magnitude > 0.1 then
					local raw = dir.Unit
					lastMoveDir = lastMoveDir:Lerp(raw, _G.LegitSmoothness)
					currentSpeed = currentSpeed + (1 - currentSpeed) * _G.LegitSmoothness
					Humanoid:Move(lastMoveDir * currentSpeed, false)
				end
			end
		end
	end

	BtnV1.Text = "V1\n" .. (_G.AutoGuardV1 and "ON" or "OFF")
	BtnV2.Text = "V2\n" .. (_G.AutoGuardV2 and "ON" or "OFF")
	BtnLegit.Text = "Legit\n" .. (_G.LegitAutoGuard and "ON" or "OFF")

end)

